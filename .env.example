# =============================================================================
# CetakKartu.com — Environment Variables
# Copy ke .env dan isi sebelum deploy
# =============================================================================

# Port untuk akses web (default 80)
PORT=80

# Secret key untuk JWT — WAJIB DIGANTI (string random panjang)
JWT_SECRET=change-this-to-a-long-random-string

# Login admin dashboard (/jaka)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
