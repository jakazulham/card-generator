# =============================================================================
# CetakKartu.com — Production Environment Variables
# Copy this file to .env and fill in your values before deployment
# =============================================================================

# --- Backend (Express API) ---
# Secret key for JWT token signing — use a long random string
JWT_SECRET=change-this-to-a-random-64-char-string

# Admin credentials for /jaka dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# --- Database ---
# SQLite database file path (inside backend container)
DB_PATH=/app/data/blog.db

# --- Ports ---
# Frontend (nginx) port
FRONTEND_PORT=80
# Backend (Express API) port
BACKEND_PORT=3001

# --- Upload ---
# Max file upload size in bytes (5MB default)
MAX_FILE_SIZE=5242880
